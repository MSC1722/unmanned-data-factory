# ── 실행 환경 ─────────────────────────────────────────────
APP_ENV=development
LOG_LEVEL=INFO

# ── 스크레이핑 대상 ────────────────────────────────────────
# 실제 대상 사이트(이베이 검색 결과 페이지, RSS 피드 등)의 base URL.
# USE_MOCK_DATA=true 인 동안에는 사용되지 않는다.
TARGET_BASE_URL=https://example.com/search
REQUEST_TIMEOUT=10
USER_AGENT=Mozilla/5.0 (compatible; DataFactoryBot/1.0; +https://example.com/bot)

# ── 파이프라인 ────────────────────────────────────────────
# 수집된 데이터를 JSONL로 적재할 디렉터리 (다음 프로세스가 여기서 읽어감)
OUTBOX_DIR=outbox

# true면 네트워크 요청 없이 내장 목(mock) 데이터를 사용한다.
# 실제 타깃 사이트가 정해지면 false로 바꾸고 TARGET_BASE_URL을 채운다.
USE_MOCK_DATA=true

# ── AI API (카메라 도메인) ────────────────────────────────
# 비워두면 각 서비스가 규칙 기반 fallback으로 동작한다 (개발/테스트용).
GEMINI_API_KEY=
CLAUDE_API_KEY=
GEMINI_MODEL=gemini-3.5-flash
CLAUDE_MODEL=claude-sonnet-5

# ── 환율/글로벌 마진 연산 (카메라 도메인, USD 기준) ────────────
# 실시간 환율 API 연동 전까지 사용하는 고정 환율. USD는 기준 통화라 환율 불필요.
FX_RATE_JPY_USD=0.006667

# 모든 매물에 공통 적용하는 글로벌 표준 배송비 (USD)
GLOBAL_SHIPPING_FEE_USD=40.0

# ── 카메라 도메인 백그라운드 스케줄러 ───────────────────────
# 이베이 Browse API를 주기적으로 수집해 free/premium-signals를 채우는 루프.
# 오프라인 개발/테스트 시 false로 끄고 /api/v1/test-feed(Mock)만 써도 된다.
CAMERA_SCHEDULER_ENABLED=true
CAMERA_SCRAPE_INTERVAL_SECONDS=300

# ── eBay Browse API (공식 개발자 API) ───────────────────────
# https://developer.ebay.com 에서 애플리케이션 등록 후 발급되는 값.
# 비어 있으면 스케줄러가 매 사이클 경고 로그만 남기고 0건을 반환한다.
# App ID/Cert ID가 SBX-로 시작하면 sandbox, PRD-로 시작하면 production.
EBAY_CLIENT_ID=
EBAY_CLIENT_SECRET=
EBAY_ENV=production

# ── AI 응답 캐시 (SQLite) ───────────────────────────────────
AI_CACHE_DB_PATH=cache.db
